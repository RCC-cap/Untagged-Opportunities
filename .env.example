# THOR — Required Environment Variables
# Copy to .env and fill in actual values

# ── Azure Blob Storage (source file) ─────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=thor-data
BLOB_FILE_NAME=VBA 1.xlsm

# ── Azure Cosmos DB (state store) ────────────────────────────────────
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_KEY=<primary-key>
COSMOS_DATABASE=thor
COSMOS_CONTAINER=pipeline-state

# ── Azure OpenAI (LLM reasoning) ────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Webhook Security ────────────────────────────────────────────────
WEBHOOK_HMAC_SECRET=<generate-a-random-64-char-hex-string>

# ── SharePoint (legacy — only needed if using sharepoint_reader.py) ──
# SHAREPOINT_TENANT_ID=<tenant-id>
# SHAREPOINT_CLIENT_ID=<client-id>
# SHAREPOINT_CLIENT_SECRET=<client-secret>
# SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
# SHAREPOINT_FILE_PATH=/Shared Documents/VBA 1.xlsm

# ── n8n Notifications ───────────────────────────────────────────────
SALES_OPS_EMAIL=sales-ops@company.com
ADMIN_EMAIL=admin@company.com
